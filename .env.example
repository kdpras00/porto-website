# ============================================
# Environment Variables Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control

# ============================================
# Gmail Configuration for Contact Form
# ============================================
# These credentials are used to send emails from the contact form API
# The contact form will send emails using Nodemailer with Gmail SMTP

# Your Gmail email address
# Example: yourname@gmail.com
GMAIL_USER=your-email@gmail.com

# Your Gmail App Password (NOT your regular Gmail password)
# 
# IMPORTANT: You need to generate an App Password from Google Account:
# 1. Go to your Google Account: https://myaccount.google.com/
# 2. Navigate to Security settings
# 3. Enable 2-Step Verification (if not already enabled)
# 4. Go to Security > App passwords (or visit: https://myaccount.google.com/apppasswords)
# 5. Select "Mail" as the app and "Other" as the device
# 6. Generate and copy the 16-character app password
# 7. Paste it here (no spaces needed)
#
# Example: abcd efgh ijkl mnop (enter as: abcdefghijklmnop)
GMAIL_PASS=your-app-password

